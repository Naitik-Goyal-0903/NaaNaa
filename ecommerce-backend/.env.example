# Copy to .env and fill in values
MONGODB_URI=mongodb://localhost:27017/naananaa
# Optional Atlas fallback without SRV lookup (use only if mongodb+srv DNS is blocked)
MONGODB_URI_DIRECT=
JWT_SECRET=replace_with_secure_secret
PORT=5000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Seed admin credentials (used by npm run seed)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change_this_strong_password
SEED_ADMIN_EMAIL=admin@naananaa.local
